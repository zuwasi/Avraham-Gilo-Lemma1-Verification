Cell[CellGroupData[{

Cell["6. Numerical Verification: d(alpha*)/dP Over Full P Range", "Section",ExpressionUUID->"65c45cdb-fe0e-5642-b8fe-d93928df5f0a"],

Cell["\<\
We numerically compute alpha*(P) for the full range P in (0,1) and plot it.
If Lemma 1(i) holds, we should see a hump-shaped (single-peaked) curve.\
\>", "Text",ExpressionUUID->"1a24f836-5c04-ea4a-b04e-d699c68b1064"],

Cell["\<\
(* Compute alpha*(P) curve for CRRA *)
computeAlphaCurve[ww_, qq_, hh_, gg_, nPts_: 200] := Module[
  {pValues, alphaValues},
  pValues = Table[pp, {pp, 0.005, 1/qq - 0.005, (1/qq - 0.01) / nPts}];
  alphaValues = Map[
    Function[pp, {pp, solveAlphaCRRA[ww, qq, pp, hh, gg]}],
    pValues
  ];
  alphaValues
];

(* Compute for several gamma values *)
Module[{curves, plots},
  curves = Table[
    {gg, computeAlphaCurve[100, 1.3, 40, gg]},
    {gg, {0.5, 1, 2, 3, 5, 8}}
  ];
  plots = Table[
    ListLinePlot[
      curves[[ii, 2]],
      PlotLabel -> StringForm[\"\[Gamma] = `1`\", curves[[ii, 1]]],
      AxesLabel -> {\"P\", \"\[Alpha]*(P)\"},
      PlotStyle -> {Thick, ColorData[97][ii]},
      PlotRange -> {0, 1}
    ],
    {ii, Length[curves]}
  ];
  Show[plots,
    PlotLabel -> \"Optimal Coverage \[Alpha]*(P) for Various CRRA \[Gamma]\",
    AxesLabel -> {\"Accident Probability P\", \"Coverage \[Alpha]*\"},
    PlotLegends -> Map[StringForm[\"\[Gamma]=`1`\", #[[1]]] &, curves],
    ImageSize -> 600,
    Frame -> True,
    FrameLabel -> {\"Accident Probability P\", \"Optimal Coverage \
\[Alpha]*(P)\"},
    GridLines -> Automatic
  ]
];\
\>", "Input",
 CellLabel->
  "In[904]:=",ExpressionUUID->"3193fbc7-967c-7446-8840-efadaf504404"]
}, Open  ]],

Cell[CellGroupData[{

Cell["7. CRRA Application: Analytical Verification of Lemma 1(i)", "Section",ExpressionUUID->"c61a5299-4aa5-1a45-95aa-97d32cfb0362"],

Cell["\<\
For CRRA utility U(A) = A^(1-gamma)/(1-gamma):
  Ra(A) = gamma/A  (decreasing in A, i.e., DARA)

Substituting into Equation (19):
  gamma/W - gamma/(W - H*(1-alpha)) < (1-q)/(alpha*q*H)

Since W1 > W2 (because the accident reduces wealth), we have Ra(W1) < Ra(W2),
so Ra(W) - Ra(W-H*(1-alpha)) < 0. The RHS is also < 0 for q > 1.

The condition becomes (after multiplying both sides by -1 and flipping \
inequality):
  gamma*H*(1-alpha) / [W*(W-H*(1-alpha))] > (q-1)/(alpha*q*H)

This is an inequality in gamma, W, H, q, alpha. We verify it numerically and
derive the critical gamma threshold.\
\>", "Text",ExpressionUUID->"2899e162-d13a-164b-a313-f37b1bdf9b41"],

Cell[CellGroupData[{

Cell["7.1 Critical Gamma Threshold", "Subsection",ExpressionUUID->"800c298e-9a39-6b44-bad6-02f1cc0b98c2"],

Cell[CellGroupData[{

Cell["\<\
(* For CRRA, find the critical gamma that makes the numerator at P~0 exactly \
zero *)
(* gamma = (q-1)*W*(W-H*(1-alpha)) / (alpha*q*H^2*(1-alpha)) *)

gammaCritical[ww_, aa_, qq_, hh_] := Module[
  {num, den},
  (* Guard against division by zero *)
  If[aa < 0.0001 || aa > 0.9999, Return[Infinity]];
  num = (qq - 1) * ww * (ww - hh * (1 - aa));
  den = aa * qq * hh^2 * (1 - aa);
  If[Abs[den] < 10^-12, Return[Infinity]];
  N[num / den]
];

Print[\"=== Critical Gamma Threshold ===\"];
Print[\"For gamma > gammaCritical: Lemma 1(i) condition holds (single-peaked \
demand)\"];
Print[\"For gamma < gammaCritical: Lemma 1(ii) may hold (monotone decreasing \
demand)\"];
Print[\"\"];

Do[
  Module[{aApprox, gc},
    aApprox = solveAlphaCRRA[100, qq, 0.01, 40, 2.0];
    gc = gammaCritical[100, aApprox, qq, 40];
    If[aApprox < 0.0001,
      Print[\"q = \", qq, \", alpha*(P~0, gamma=2) = 0 [no coverage]\"],
      Print[\"q = \", qq, \", alpha*(P~0, gamma=2) = \", Round[aApprox, 0.001],
        \", gammaCritical = \", If[gc === Infinity, \"Infinity\", Round[gc, \
0.01]]]
    ]
  ],
  {qq, {1.05, 1.1, 1.2, 1.3, 1.5, 2.0}}
];\
\>", "Input",
 CellLabel->
  "In[909]:=",ExpressionUUID->"891e8ad1-69d6-2f4e-97e2-bd9d4097ceaa"],

