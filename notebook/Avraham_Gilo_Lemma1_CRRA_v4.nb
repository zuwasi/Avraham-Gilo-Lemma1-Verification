Cell[CellGroupData[{

Cell["5.4 Limit Analysis: P -> 1", "Subsection",ExpressionUUID->"de47cc4e-7236-9446-a6c0-c9e7903ceee5"],

Cell["\<\
As P -> 1, the paper shows (p.24):
  - alpha* -> 0 (coverage vanishes)
  - The squared bracket on the LHS of Eq.(14) converges to H*(1-q)^2 * \
U''(W2) < 0
  - The RHS converges to q*[U'(W2) - U'(W1)] > 0 (by concavity)
  - Therefore d(alpha)/dP < 0 as P -> 1

This proves that if d(alpha)/dP > 0 near P=0 (Lemma 1(i) condition),
then there must exist a P-bar in (0,1) that maximizes alpha* (single-peaked).\
\
\>", "Text",ExpressionUUID->"dc3d2c36-03ce-fe42-baf3-5ce91fa65631"],

Cell[CellGroupData[{

Cell["\<\
(* Verify the P -> 1 limit for CRRA *)
verifyPto1Limit[ww_, qq_, hh_, gg_] := Module[
  {pTest, aOpt, w1, w2, up1, up2, lhsBracket, rhsVal},
  pTest = 0.999;
  aOpt = solveAlphaCRRA[ww, qq, pTest, hh, gg];
  w1 = wealth1[ww, aOpt, qq, pTest, hh];
  w2 = wealth2[ww, aOpt, qq, pTest, hh];
  If[w1 <= 0 || w2 <= 0,
    Return[<|\"P\" -> pTest, \"alpha*\" -> N[aOpt],
      \"LHS bracket\" -> \"N/A (non-positive wealth)\",
      \"RHS\" -> \"N/A\",
      \"d(alpha)/dP sign\" -> \"INDETERMINATE\"|>]
  ];
  up1 = crrAutilityPrime[w1, gg];
  up2 = crrAutilityPrime[w2, gg];
  lhsBracket = hh * (1 - qq)^2 * crrAutilityDoublePrime[w2, gg];
  rhsVal = qq * (up2 - up1);
  <|
    \"P\" -> pTest,
    \"alpha*\" -> N[aOpt],
    \"LHS bracket (should be < 0)\" -> N[lhsBracket],
    \"RHS (should be > 0)\" -> N[rhsVal],
    \"d(alpha)/dP sign\" -> If[N[lhsBracket] < 0 && N[rhsVal] > 0, \"NEGATIVE \
(confirmed)\", \"CHECK NEEDED\"]
  |>
];

Print[\"=== P -> 1 Limit Verification ===\"];
Do[
  Print[\"gamma = \", gg, \": \", verifyPto1Limit[100, 1.3, 40, gg]],
  {gg, {0.5, 1, 2, 5}}
];\
\>", "Input",
 CellLabel->
  "In[899]:=",ExpressionUUID->"15f81377-7b23-eb4f-83ed-067c6536ca9b"],

