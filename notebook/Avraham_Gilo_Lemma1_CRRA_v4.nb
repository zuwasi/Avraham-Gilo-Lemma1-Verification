Cell[CellGroupData[{

Cell["2. Wealth Definitions in Both States", "Section",ExpressionUUID->"a241aa79-9204-2143-90e5-b0ed2160ab3e"],

Cell["\<\
From the paper (p.10):
  State 1 (no accident):  W1 = W - alpha * q * P * H
  State 2 (accident):    W2 = W - H + alpha * H * (1 - q * P)
                       = W - alpha * q * P * H - (1 - alpha) * H\
\>", "Text",ExpressionUUID->"e0ad52f5-7528-0e4a-98bd-56b2536de9d3"],

Cell[CellGroupData[{

Cell["\<\
(* Wealth in state 1: no accident *)
wealth1[ww_, aa_, qq_, pp_, hh_] := ww - aa * qq * pp * hh;

(* Wealth in state 2: accident *)
wealth2[ww_, aa_, qq_, pp_, hh_] := ww - aa * qq * pp * hh - (1 - aa) * hh;

(* Verification: W2 can also be written as W - H + alpha*H*(1 - q*P) *)
Simplify[wealth2[ww, aa, qq, pp, hh] - (ww - hh + aa * hh * (1 - qq * pp))]
(* Should return 0 *)\
\>", "Input",
 CellLabel->
  "In[836]:=",ExpressionUUID->"d9d79cfa-c0ca-6f48-be6a-5e60da7e1640"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.9839358755448647`*^9, 3.9840311751993904`*^9, 
  3.9840458568257427`*^9},
 CellLabel->
  "Out[843]=",ExpressionUUID->"d9ed0c05-59c0-d34c-a66d-c1c905a917da"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. General Utility Framework", "Section",ExpressionUUID->"9822a9a6-9f86-f44b-913d-5bb188e6db50"],

Cell["\<\
The paper assumes a general utility function U(A) with:
  U'(A) > 0  (monotonically increasing)
  U''(A) < 0  (strict concavity / risk aversion)
  U three-times continuously differentiable

Arrow-Pratt absolute risk aversion coefficient:
  Ra(A) = -U''(A) / U'(A)\
\>", "Text",ExpressionUUID->"a58c1b67-8406-e04a-8f57-d2e7f967afef"],

Cell[CellGroupData[{

Cell["\<\
(* For CRRA utility: U(A) = A^(1-gamma)/(1-gamma) when gamma != 1 *)
(* Arrow-Pratt Ra for CRRA: Ra(A) = gamma/A *)

crrAutility[aa_, gg_] := If[gg == 1, Log[aa], aa^(1 - gg) / (1 - gg)];
crrAutilityPrime[aa_, gg_] := aa^(-gg);
crrAutilityDoublePrime[aa_, gg_] := -gg * aa^(-gg - 1);
crrArrowPratt[aa_, gg_] := gg / aa;

(* Verify: Ra(A) = -U''(A)/U'(A) for CRRA *)
Simplify[-crrAutilityDoublePrime[aa, gg] / crrAutilityPrime[aa, gg] - \
crrArrowPratt[aa, gg]]
(* Should return 0 *)\
\>", "Input",
 CellLabel->
  "In[845]:=",ExpressionUUID->"59e01374-982e-9c4a-a074-09ffe3e709f6"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.9839358755538807`*^9, 3.9840311752073917`*^9, 
  3.9840458568347454`*^9},
 CellLabel->
  "Out[854]=",ExpressionUUID->"6d34706a-99ad-6044-afee-e3033c3576c6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. First-Order Condition (FOC) for Optimal Coverage", "Section",ExpressionUUID->"ed797b0e-8c4c-164d-9763-b46139205080"],

Cell["\<\
Equation (1) from the paper (p.10). A consumer of type theta maximizes \
expected utility:
  EU = (1-P) * U(W1) + P * U(W2)
with respect to alpha. The FOC is:
  -(1-P) * q * P * H * U'(W1) + P * H * (1 - q*P) * U'(W2) = 0

Dividing by P*H (which is positive) gives Equation (10):
  -(1-P) * q * U'(W1) + (1 - q*P) * U'(W2) = 0

This implies the key substitution used throughout the proof:
  U'(W2) = U'(W1) * (1-P)*q / (1-q*P)     ... (from FOC)\
\>", "Text",ExpressionUUID->"6eb07939-d714-8b4c-abf3-de4cbf826c15"],

Cell[CellGroupData[{

Cell["\<\
(* FOC for CRRA utility *)
focCRRA[ww_, aa_, qq_, pp_, hh_, gg_] := Module[
  {w1, w2},
  w1 = wealth1[ww, aa, qq, pp, hh];
  w2 = wealth2[ww, aa, qq, pp, hh];
  -(1 - pp) * qq * crrAutilityPrime[w1, gg] + (1 - qq * pp) * \
crrAutilityPrime[w2, gg]
];

Print[\"FOC function defined.\"];\
\>", "Input",
 CellLabel->
  "In[856]:=",ExpressionUUID->"0d3fe76d-8711-b045-afcb-fa477e4d263f"],

Cell[BoxData["\<\"FOC function defined.\"\>"], "Print",
 CellChangeTimes->{3.983935875555872*^9, 3.98403117521039*^9, 
  3.9840458568377457`*^9},
 CellLabel->
  "During evaluation of \
In[856]:=",ExpressionUUID->"22e02ff5-169a-5b44-8356-6be98cc60083"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.1 Numerical Solution of Optimal Coverage (CRRA)", "Subsection",ExpressionUUID->"4f7d075a-d69b-a349-ae57-105e1bb6fa2e"],

Cell[CellGroupData[{

Cell["\<\
(* Solve FOC for alpha given parameters, using CRRA utility *)
solveAlphaCRRA[ww_, qq_, pp_, hh_, gg_] := Module[
  {sol, aVal, f},
  (* Check boundary: if q*P >= 1, no positive coverage is optimal *)
  If[qq * pp >= 1, Return[0.0]];
  (* Define the function to find root of *)
  f[av_?NumericQ] := focCRRA[ww, av, qq, pp, hh, gg];
  (* Try bracketed FindRoot first *)
  sol = Quiet[Check[
    FindRoot[f[av], {av, 0.001, 0.999}],
    $Failed
  ]];
  If[sol =!= $Failed,
    aVal = av /. sol;
    Return[N[Max[0, Min[1, aVal]]]]
  ];
  (* Fallback: Newton method *)
  sol = Quiet[Check[
    FindRoot[f[av], {av, 0.5}],
    $Failed
  ]];
  If[sol =!= $Failed,
    aVal = av /. sol;
    N[Max[0, Min[1, aVal]]],
    0.0
  ]
];

(* Test with default parameters *)
Module[{aOpt},
  aOpt = solveAlphaCRRA[100, 1.3, 0.1, 40, 2.0];
  Print[\"Test: optimal alpha (CRRA, gamma=2) = \", aOpt];
  Print[\"  W1 = \", wealth1[100, aOpt, 1.3, 0.1, 40]];
  Print[\"  W2 = \", wealth2[100, aOpt, 1.3, 0.1, 40]];
];\
\>", "Input",
 CellLabel->
  "In[860]:=",ExpressionUUID->"389a57a9-808b-ce45-be9e-c205c855b1e8"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
