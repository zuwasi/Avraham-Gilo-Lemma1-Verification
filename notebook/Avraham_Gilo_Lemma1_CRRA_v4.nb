In[865]:=",ExpressionUUID->"b826c1ed-f86d-ab4a-89f3-6e944e18e5f7"],

Cell[BoxData["\<\"w.r.t. P yields exactly the expression in the paper's \
Appendix.\"\>"], "Print",
