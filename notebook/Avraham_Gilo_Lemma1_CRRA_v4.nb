Cell[CellGroupData[{

Cell["7.2 Phase Diagram: Lemma 1(i) vs 1(ii) Regions", "Subsection",ExpressionUUID->"ed0e50be-4fda-8e4a-987c-b84dada8169f"],

Cell["\<\
(* Phase diagram showing which (gamma, q) combinations satisfy Lemma 1(i) *)
Module[{phaseData},
  phaseData = Table[
    Module[{aOpt, numP0, numVal},
      aOpt = Quiet[solveAlphaCRRA[100, qq, 0.01, 40, gg]];
      If[aOpt < 0.0001,
        {qq, gg, 0},  (* no coverage => monotone *)
        numP0 = Quiet[numeratorLimitP0CRRA[100, aOpt, qq, 40, gg]];
        numVal = N[numP0];
        If[NumericQ[numVal],
          {qq, gg, If[numVal < 0, 1, 0]},
          {qq, gg, 0}
        ]
      ]
    ],
    {qq, 1.01, 2.0, 0.05},
    {gg, 0.5, 10, 0.25}
  ];
  phaseData = Flatten[phaseData, 1];
  ListDensityPlot[
    phaseData,
    PlotLabel -> \"Phase Diagram: Lemma 1(i) vs 1(ii) for CRRA\",
    FrameLabel -> {\"Loading Factor q\", \"CRRA Coefficient \[Gamma]\"},
    ColorFunction -> (If[# > 0.5, RGBColor[0.2, 0.6, 0.2], RGBColor[0.8, 0.2, \
0.2]] &),
    PlotLegends -> SwatchLegend[{RGBColor[0.2, 0.6, 0.2], RGBColor[0.8, 0.2, \
0.2]},
      {\"Lemma 1(i): Single-peaked\", \"Lemma 1(ii): Monotone decreasing\"}],
    ImageSize -> 600,
    Frame -> True
  ]
];\
\>", "Input",
 CellLabel->
  "In[920]:=",ExpressionUUID->"83a82e5c-8f10-0844-ba57-7ab89b64ef08"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["8. Interactive Exploration: Manipulate Panels", "Section",ExpressionUUID->"32b1a3a6-ca4b-8b43-83f1-629fbb4c6676"],

Cell["\<\
The following interactive panels allow you to explore the model with sliders.
Adjust parameters and observe how optimal coverage, the Lemma 1 conditions,
and the demand curve respond in real time.\
\>", "Text",ExpressionUUID->"17818e33-4bd7-d247-83ef-c3645ddabe4e"],

Cell[CellGroupData[{

Cell["8.1 Panel 1: Coverage Curve and Lemma 1 Diagnostic", "Subsection",ExpressionUUID->"38cf5285-a839-9342-816a-8e0fe60dafda"],

Cell[CellGroupData[{

Cell["\<\
Manipulate[
  Module[
    {pVals, alphaVals, pStar, alphaStar, numP0, condText,
     alphaAtP0, critGam, numVal},
    SeedRandom[42];
    pVals = Table[pp, {pp, 0.005, 1/qVal - 0.005, (1/qVal - 0.01) / 150}];
    alphaVals = Map[
      Function[pp, {pp, Quiet[solveAlphaCRRA[wVal, qVal, pp, hVal, \
gammaVal]]}],
      pVals
    ];
    {pStar, alphaStar} = First[SortBy[alphaVals, -Last[#] &]];
    alphaAtP0 = Quiet[solveAlphaCRRA[wVal, qVal, 0.01, hVal, gammaVal]];
    numP0 = Quiet[numeratorLimitP0CRRA[wVal, alphaAtP0, qVal, hVal, gammaVal]];
    numVal = N[numP0];
    critGam = gammaCritical[wVal, alphaAtP0, qVal, hVal];
    condText = If[NumericQ[numVal] && numVal < 0,
      Style[\"Lemma 1(i) HOLDS: Single-peaked demand\", Bold, Darker[Green]],
      Style[\"Lemma 1(ii): Monotone decreasing demand\", Bold, Red]
    ];
    Column[{
      condText,
      Row[{
        StringForm[\"P* = `1`, \[Alpha]* = `2`\", Round[pStar, 0.001], \
Round[alphaStar, 0.001]],
        Spacer[20],
        StringForm[\"Num(P\[RightArrow]0) = `1`\", If[NumericQ[numVal], \
Round[numVal, 0.0001], \"N/A\"]],
        Spacer[20],
        StringForm[\"\[Gamma]crit = `1`\", If[NumericQ[critGam] && critGam < \
10^6, Round[critGam, 0.01], \"N/A\"]]
      }],
      ListLinePlot[alphaVals,
        PlotLabel -> StringForm[\"\[Alpha]*(P)  |  W=`1`, H=`2`, q=`3`, \
\[Gamma]=`4`\", wVal, hVal, qVal, gammaVal],
        AxesLabel -> {\"P\", \"\[Alpha]*(P)\"},
        PlotStyle -> {Thick, Blue},
        PlotRange -> {{0, 1/qVal}, {0, 1}},
        Epilog -> {
          Red, PointSize[Large], Point[{pStar, alphaStar}],
          Text[Style[StringForm[\"Peak: (`1`,`2`)\", Round[pStar, 0.01], \
Round[alphaStar, 0.01]], 10, Red],
            {pStar, alphaStar}, {0, -1.5}]
        },
        ImageSize -> 500,
        Frame -> True,
        FrameLabel -> {\"Accident Probability P\", \"Optimal Coverage \
\[Alpha]*\"},
        GridLines -> Automatic
      ]
    }]
  ],
  {{wVal, 100, \"Wealth W\"}, 50, 500, 10, Appearance -> \"Labeled\"},
  {{hVal, 40, \"Harm H\"}, 5, 80, 5, Appearance -> \"Labeled\"},
  {{qVal, 1.3, \"Loading q\"}, 1.01, 3.0, 0.01, Appearance -> \"Labeled\"},
  {{gammaVal, 2.0, \"CRRA \[Gamma]\"}, 0.1, 15.0, 0.1, Appearance -> \
\"Labeled\"},
  TrackedSymbols :> {wVal, hVal, qVal, gammaVal},
  ControlPlacement -> Left
]\
\>", "Input",
 CellLabel->
  "In[922]:=",ExpressionUUID->"54a0848a-5634-6c4d-afaa-3eeb38b35045"],

