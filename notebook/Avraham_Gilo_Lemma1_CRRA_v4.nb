Cell[CellGroupData[{
Cell["\<\
Avraham & Gilo (2025) \[LongDash] Lemma 1 Verification and CRRA Application\
\>", "Title",ExpressionUUID->"549093e3-0463-f248-af52-2bcd33346107"],

Cell["\<\
Insurance Collusion and Imperfect Competition when Insurers Increase Risk\
\>", "Subtitle",ExpressionUUID->"adcab441-4e65-f743-aeba-297eb9016159"],

Cell["\<\
Computational verification of Lemma 1 and its proof (Appendix), with \
application to CRRA utility consumers.
Prepared for Professor David Gilo, Tel Aviv University Faculty of Law.\
\>", "Text",ExpressionUUID->"d0a1f37c-e66b-2640-b558-e475b9f6d374"],

Cell[CellGroupData[{

Cell["1. Model Setup and Parameter Definitions", "Section",ExpressionUUID->"f2eb3fcc-1a3e-944f-b4b0-21d8cfe51b24"],

Cell["\<\
This section defines all model primitives from Avraham & Gilo (2025), Section \
II.

Key Variables:
  W = initial wealth (W > H)
  H = harm magnitude (H > 0)
  P = probability of accident, P in (0,1)
  q = loading factor (q >= 1; q=1 is actuarially fair)
  alpha = coverage fraction, alpha in [0,1]
  theta = risk aversion parameter (heterogeneity index)
  gamma = CRRA coefficient (for CRRA utility specialization)\
\>", "Text",ExpressionUUID->"86825df4-a0b1-994c-a17d-579379df68e5"],

Cell[CellGroupData[{

Cell["\<\
(* --- Reproducibility --- *)
SeedRandom[42];

(* === Model Parameters (Association) === *)
modelParams = <|
  \"W\" -> 100,       (* initial wealth *)
  \"H\" -> 40,        (* harm magnitude, must be < W *)
  \"qMin\" -> 1.01,   (* minimum loading factor, supra-competitive *)
  \"qMax\" -> 2.0,    (* maximum loading factor *)
  \"qDefault\" -> 1.3,(* default loading factor for demonstrations *)
  \"thetaMin\" -> 0.5,(* minimum risk aversion *)
  \"thetaMax\" -> 5.0, (* maximum risk aversion *)
  \"gammaMin\" -> 0.5,(* CRRA: minimum gamma *)
  \"gammaMax\" -> 10.0,(* CRRA: maximum gamma *)
  \"nTheta\" -> 50     (* number of theta grid points for integration *)
|>;

Print[\"Model parameters loaded:\"];
Print[modelParams];\
\>", "Input",
 CellLabel->
  "In[828]:=",ExpressionUUID->"47fe30b4-b155-5e42-9f65-53874f5ad020"],

