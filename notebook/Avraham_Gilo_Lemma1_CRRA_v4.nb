In[865]:=",ExpressionUUID->"0236c313-8611-9b4d-9a22-0665e49fb322"],

Cell[BoxData["\<\"      = -alphaOfP'[P]*H*(q*P - 1) - alphaOfP[P]*q*H\"\>"], \
"Print",
 CellChangeTimes->{3.9839358755668774`*^9, 3.984031175224476*^9, 
  3.9840458568537464`*^9},
 CellLabel->
  "During evaluation of \
In[865]:=",ExpressionUUID->"4e366a77-3e0f-ef49-8775-ba2eaa7d381d"],

Cell[BoxData["\<\"\\nEquation (14) verified by construction: the total \
derivative of the FOC\"\>"], "Print",
 CellChangeTimes->{3.9839358755668774`*^9, 3.984031175224476*^9, 
  3.9840458568537464`*^9},
