Cell[CellGroupData[{

Cell["10. Validation Summary", "Section",ExpressionUUID->"0f68af42-eccc-494f-a01e-29ca822120a9"],

Cell[CellGroupData[{

Cell["\<\
(* ========== VALIDATION REPORT ========== *)

Print[\"\\n========================================\"];
Print[\"   VALIDATION REPORT\"];
Print[\"========================================\"];

Module[{aOpt, focVal},
  aOpt = solveAlphaCRRA[100, 1.3, 0.15, 40, 3.0];
  focVal = focCRRA[100, aOpt, 1.3, 0.15, 40, 3.0];
  Print[\"\\n1. FOC Consistency Check:\"];
  Print[\"   alpha* = \", aOpt];
  Print[\"   FOC(alpha*) = \", focVal, If[Abs[focVal] < 10^-8, \"  PASS\", \" \
 FAIL\"]];
];

Module[{aOpt, w1, w2},
  aOpt = solveAlphaCRRA[100, 1.3, 0.15, 40, 3.0];
  w1 = wealth1[100, aOpt, 1.3, 0.15, 40];
  w2 = wealth2[100, aOpt, 1.3, 0.15, 40];
  Print[\"\\n2. Wealth Ordering (W1 > W2 for q > 1):\"];
  Print[\"   W1 = \", w1, \", W2 = \", w2, If[w1 > w2, \"  PASS\", \"  \
FAIL\"]];
];

Module[{raManual, raFormula},
  raManual = -crrAutilityDoublePrime[75.3, 2.5] / crrAutilityPrime[75.3, 2.5];
  raFormula = crrArrowPratt[75.3, 2.5];
  Print[\"\\n3. Arrow-Pratt Identity (Ra = gamma/A):\"];
  Print[\"   -U''/U' = \", raManual, \", gamma/A = \", raFormula,
    If[Abs[raManual - raFormula] < 10^-12, \"  PASS\", \"  FAIL\"]];
];

Module[{aOpt, result},
  aOpt = solveAlphaCRRA[100, 1.3, 0.15, 40, 3.0];
  result = dAlphaDpCRRA[100, aOpt, 1.3, 0.15, 40, 3.0];
  Print[\"\\n4. Denominator of Eq.(17) < 0:\"];
  Print[\"   Denominator = \", result[\"Denominator\"],
    If[result[\"Denominator\"] < 0, \"  PASS\", \"  FAIL\"]];
];

Module[{limitResult},
  limitResult = verifyPto1Limit[100, 1.3, 40, 3.0];
  Print[\"\\n5. P -> 1 Limit (d(alpha)/dP < 0):\"];
  Print[\"   \", limitResult[\"d(alpha)/dP sign\"]];
];

Module[{run1, run2},
  SeedRandom[42]; run1 = solveAlphaCRRA[100, 1.3, 0.1, 40, 2.0];
  SeedRandom[42]; run2 = solveAlphaCRRA[100, 1.3, 0.1, 40, 2.0];
  Print[\"\\n6. Reproducibility (fixed seed):\"];
  Print[\"   Run 1 = \", run1, \", Run 2 = \", run2,
    If[run1 == run2, \"  PASS\", \"  FAIL\"]];
];

Print[\"\\n========================================\"];
Print[\"   END VALIDATION REPORT\"];
Print[\"========================================\"];\
\>", "Input",
 CellLabel->
  "In[602]:=",ExpressionUUID->"70c04a15-f3ac-e14f-96f7-7cf77651cedf"],

