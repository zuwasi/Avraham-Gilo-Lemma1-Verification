$CellContext`qVal2$$, $CellContext`pp$, $CellContext`hVal2$$, \
$CellContext`gammaVal2$$]]; $CellContext`w1v$ = \
$CellContext`wealth1[$CellContext`wVal2$$, $CellContext`aOpt$, \
$CellContext`qVal2$$, $CellContext`pp$, $CellContext`hVal2$$]; \
$CellContext`w2v$ = $CellContext`wealth2[$CellContext`wVal2$$, \
$CellContext`aOpt$, $CellContext`qVal2$$, $CellContext`pp$, \
$CellContext`hVal2$$]; If[
               Or[$CellContext`w1v$ <= 0, $CellContext`w2v$ <= 0], <|
               "P" -> $CellContext`pp$, "alpha" -> $CellContext`aOpt$, "RaW1" -> 
                0, "RaW2" -> 0, "Num" -> 0, "Den" -> -1, "Deriv" -> 
                0|>, $CellContext`ra1v$ = \
$CellContext`crrArrowPratt[$CellContext`w1v$, $CellContext`gammaVal2$$]; \
$CellContext`ra2v$ = $CellContext`crrArrowPratt[$CellContext`w2v$, \
$CellContext`gammaVal2$$]; $CellContext`num17v$ = (
                   1 - $CellContext`pp$) $CellContext`aOpt$ \
$CellContext`qVal2$$ $CellContext`hVal2$$ ($CellContext`ra1v$ - \
$CellContext`ra2v$) + ($CellContext`qVal2$$ - 1)/(
                  1 - $CellContext`qVal2$$ $CellContext`pp$); \
$CellContext`den17v$ = (-(
                   1 - $CellContext`pp$)) $CellContext`hVal2$$ \
($CellContext`qVal2$$ $CellContext`pp$ $CellContext`ra1v$ + (
                    1 - $CellContext`qVal2$$ $CellContext`pp$) \
$CellContext`ra2v$); $CellContext`derivv$ = 
                If[Abs[$CellContext`den17v$] > 
                  10^(-12), $CellContext`num17v$/$CellContext`den17v$, 0]; <|
                "P" -> $CellContext`pp$, "alpha" -> $CellContext`aOpt$, 
                 "RaW1" -> $CellContext`ra1v$, "RaW2" -> $CellContext`ra2v$, 
                 "Num" -> $CellContext`num17v$, "Den" -> $CellContext`den17v$,
                  "Deriv" -> $CellContext`derivv$|>]]], $CellContext`pVals$]; 
        Column[{
           Style["Equation (17) Decomposition", Bold, 14], 
           GraphicsRow[{
             ListLinePlot[{
               Map[{
                 #["P"], 
                 #["RaW1"]}& , $CellContext`plotData$], 
               Map[{
                 #["P"], 
                 #["RaW2"]}& , $CellContext`plotData$]}, PlotLabel -> 
              "Arrow-Pratt Ra in Both States", 
              PlotLegends -> {"Ra(W1)", "Ra(W2)"}, 
              PlotStyle -> {{Thick, Blue}, {Thick, Red}}, Frame -> True, 
              FrameLabel -> {"P", "Ra"}, ImageSize -> 280], 
             ListLinePlot[{
               Map[{
                 #["P"], 
                 #["Num"]}& , $CellContext`plotData$], 
               Map[{
                 #["P"], 
