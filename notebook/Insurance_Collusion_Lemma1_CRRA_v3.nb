Cell[CellGroupData[{

Cell["5.2 Equation (17): Closed-Form Expression for d(alpha)/dP", "Subsection",ExpressionUUID->"11566fa1-f377-e342-9392-456947037577"],

Cell["\<\
After substituting U''(A) = -Ra(A)*U'(A) and using the FOC relationship
  U'(W2) = U'(W1) * (1-P)*q / (1-q*P)
we obtain Equation (17):

  d(alpha)/dP = Numerator / Denominator

where:
  Numerator  = (1-P)*alpha*q*H*[Ra(W1) - Ra(W2)] + (q-1)/(1-q*P)
  Denominator = -(1-P)*H*[q*P*Ra(W1) + (1-q*P)*Ra(W2)]

Note: Denominator < 0 always (since Ra > 0, H > 0, P in (0,1)).\
\>", "Text",ExpressionUUID->"307a2cf5-8e42-bb43-b587-86d87253c41e"],

Cell[CellGroupData[{

Cell["\<\
(* Equation (17): derivative of alpha w.r.t. P *)
dAlphaDp[aa_, qq_, pp_, hh_, ra1_, ra2_] := Module[
  {num, den},
  num = (1 - pp) * aa * qq * hh * (ra1 - ra2) + (qq - 1) / (1 - qq * pp);
  den = -(1 - pp) * hh * (qq * pp * ra1 + (1 - qq * pp) * ra2);
  <|
    \"Numerator\" -> N[num],
    \"Denominator\" -> N[den],
    \"dAlpha/dP\" -> N[num / den]
  |>
];

(* For CRRA: Ra(A) = gamma/A *)
dAlphaDpCRRA[ww_, aa_, qq_, pp_, hh_, gg_] := Module[
  {w1, w2, ra1, ra2},
  w1 = wealth1[ww, aa, qq, pp, hh];
  w2 = wealth2[ww, aa, qq, pp, hh];
  ra1 = crrArrowPratt[w1, gg];
  ra2 = crrArrowPratt[w2, gg];
  dAlphaDp[aa, qq, pp, hh, ra1, ra2]
];

(* Test *)
Module[{aOpt, result},
  aOpt = solveAlphaCRRA[100, 1.3, 0.1, 40, 2.0];
  result = dAlphaDpCRRA[100, aOpt, 1.3, 0.1, 40, 2.0];
  Print[\"Eq.(17) test at P=0.1, gamma=2:\"];
  Print[\"  alpha* = \", aOpt];
  Print[\"  Numerator = \", result[\"Numerator\"]];
  Print[\"  Denominator = \", result[\"Denominator\"]];
  Print[\"  d(alpha)/dP = \", result[\"dAlpha/dP\"]];
];\
\>", "Input",
 CellLabel->
  "In[529]:=",ExpressionUUID->"2997179f-dfca-e84c-803c-918bca4c9e20"],

Cell[CellGroupData[{

Cell[BoxData["\<\"Eq.(17) test at P=0.1, gamma=2:\"\>"], "Print",
