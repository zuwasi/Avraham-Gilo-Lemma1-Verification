Cell[CellGroupData[{

Cell["8.2 Panel 2: Arrow-Pratt Decomposition", "Subsection",ExpressionUUID->"3515cd44-9415-f04f-9c06-a03ad3cebdd4"],

Cell[CellGroupData[{

Cell["\<\
Manipulate[
  Module[
    {pVals, plotData, w1v, w2v, ra1v, ra2v, num17v, den17v, derivv},
    SeedRandom[42];
    pVals = Table[pp, {pp, 0.005, 1/qVal2 - 0.005, (1/qVal2 - 0.01) / 100}];
    plotData = Map[
      Function[pp, Module[{aOpt},
        aOpt = Quiet[solveAlphaCRRA[wVal2, qVal2, pp, hVal2, gammaVal2]];
        w1v = wealth1[wVal2, aOpt, qVal2, pp, hVal2];
        w2v = wealth2[wVal2, aOpt, qVal2, pp, hVal2];
        If[w1v <= 0 || w2v <= 0,
          <|\"P\" -> pp, \"alpha\" -> aOpt, \"RaW1\" -> 0, \"RaW2\" -> 0,
            \"Num\" -> 0, \"Den\" -> -1, \"Deriv\" -> 0|>,
          ra1v = crrArrowPratt[w1v, gammaVal2];
          ra2v = crrArrowPratt[w2v, gammaVal2];
          num17v = (1 - pp) * aOpt * qVal2 * hVal2 * (ra1v - ra2v) + (qVal2 - \
1) / (1 - qVal2 * pp);
          den17v = -(1 - pp) * hVal2 * (qVal2 * pp * ra1v + (1 - qVal2 * pp) \
* ra2v);
          derivv = If[Abs[den17v] > 10^-12, num17v / den17v, 0];
          <|\"P\" -> pp, \"alpha\" -> aOpt, \"RaW1\" -> ra1v, \"RaW2\" -> ra2v,
            \"Num\" -> num17v, \"Den\" -> den17v, \"Deriv\" -> derivv|>
        ]
      ]],
      pVals
    ];
    Column[{
      Style[\"Equation (17) Decomposition\", Bold, 14],
      GraphicsRow[{
        ListLinePlot[
          {Map[{#[\"P\"], #[\"RaW1\"]} &, plotData], Map[{#[\"P\"], \
#[\"RaW2\"]} &, plotData]},
          PlotLabel -> \"Arrow-Pratt Ra in Both States\",
          PlotLegends -> {\"Ra(W1)\", \"Ra(W2)\"},
          PlotStyle -> {{Thick, Blue}, {Thick, Red}},
          Frame -> True, FrameLabel -> {\"P\", \"Ra\"},
          ImageSize -> 280
        ],
        ListLinePlot[
          {Map[{#[\"P\"], #[\"Num\"]} &, plotData], Map[{#[\"P\"], \
#[\"Den\"]} &, plotData]},
          PlotLabel -> \"Numerator & Denominator of Eq.(17)\",
          PlotLegends -> {\"Numerator\", \"Denominator\"},
          PlotStyle -> {{Thick, Orange}, {Thick, Purple}},
          Epilog -> {Dashed, Gray, Line[{{0, 0}, {1, 0}}]},
          Frame -> True, FrameLabel -> {\"P\", \"Value\"},
          ImageSize -> 280
        ]
      }, ImageSize -> 600],
      ListLinePlot[
        Map[{#[\"P\"], #[\"Deriv\"]} &, plotData],
        PlotLabel -> \"d\[Alpha]*/dP (Equation 17)\",
        PlotStyle -> {Thick, Darker[Green]},
        Epilog -> {Dashed, Red, Line[{{0, 0}, {1, 0}}]},
        Frame -> True,
        FrameLabel -> {\"P\", \"d\[Alpha]*/dP\"},
        ImageSize -> 600
      ]
    }]
  ],
  {{wVal2, 100, \"Wealth W\"}, 50, 500, 10, Appearance -> \"Labeled\"},
  {{hVal2, 40, \"Harm H\"}, 5, 80, 5, Appearance -> \"Labeled\"},
  {{qVal2, 1.3, \"Loading q\"}, 1.01, 3.0, 0.01, Appearance -> \"Labeled\"},
  {{gammaVal2, 2.0, \"CRRA \[Gamma]\"}, 0.1, 15.0, 0.1, Appearance -> \
\"Labeled\"},
  TrackedSymbols :> {wVal2, hVal2, qVal2, gammaVal2},
  ControlPlacement -> Left
]\
\>", "Input",
 CellLabel->
  "In[575]:=",ExpressionUUID->"75a4dbe5-9a0b-5844-b0b4-7a98312ad2ce"],

