Cell[CellGroupData[{

Cell["9. Data Import Interface", "Section",ExpressionUUID->"3c8845b9-649a-7141-9883-42dc3bc520eb"],

Cell["\<\
This section allows importing real or simulated datasets.
Expected CSV format: columns W, H, P, q, gamma (one row per scenario).
If no external data is available, a synthetic dataset is generated.\
\>", "Text",ExpressionUUID->"53fd456d-e3da-084c-bcb0-f62ffb92d7ab"],

Cell[CellGroupData[{

Cell["\<\
(* === Data Import / Generation === *)
loadOrGenerateData[filePath_: None] := Module[
  {rawData, nObs},
  If[filePath =!= None && FileExistsQ[filePath],
    rawData = Import[filePath, \"CSV\", \"HeaderLines\" -> 1];
    Print[\"Loaded external data: \", Length[rawData], \" observations.\"];
    Map[
      <|\"W\" -> #[[1]], \"H\" -> #[[2]], \"P\" -> #[[3]], \"q\" -> #[[4]], \
\"gamma\" -> #[[5]]|> &,
      rawData
    ],
    SeedRandom[42];
    nObs = 50;
    Print[\"No external data found. Generating \", nObs, \" synthetic \
scenarios.\"];
    Table[
      <|
        \"W\" -> RandomReal[{50, 200}],
        \"H\" -> RandomReal[{10, 80}],
        \"P\" -> RandomReal[{0.01, 0.5}],
        \"q\" -> RandomReal[{1.01, 2.0}],
        \"gamma\" -> RandomReal[{0.5, 10.0}]
      |>,
      {nObs}
    ]
  ]
];

syntheticData = loadOrGenerateData[];

analysisResults = Map[
  Function[row, Module[
    {ww, hh, pp, qq, gg, aOpt, numP0, numVal, condHolds},
    {ww, hh, pp, qq, gg} = Values[row];
    If[hh >= ww, Return[Append[row, \"Status\" -> \"Invalid: H >= W\"]]];
    aOpt = Quiet[solveAlphaCRRA[ww, qq, pp, hh, gg]];
    If[aOpt < 0.0001,
      Append[row, <|\"alpha*\" -> 0.0, \"NumP0\" -> N[qq - 1], \"Lemma1i\" -> \
\"N/A\"|>],
      numP0 = Quiet[numeratorLimitP0CRRA[ww, aOpt, qq, hh, gg]];
      numVal = N[numP0];
      condHolds = NumericQ[numVal] && numVal < 0;
      Append[row, <|
        \"alpha*\" -> Round[aOpt, 0.0001],
        \"NumP0\" -> If[NumericQ[numVal], Round[numVal, 0.0001], \"Error\"],
        \"Lemma1i\" -> If[condHolds, \"Yes\", \"No\"]
      |>]
    ]
  ]],
  syntheticData
];

Print[\"\\n=== Synthetic Data Analysis Summary ===\"];
Print[\"Total scenarios: \", Length[analysisResults]];
Print[\"Lemma 1(i) holds: \", Count[analysisResults, _?(#[\"Lemma1i\"] === \
\"Yes\" &)]];
Print[\"Lemma 1(ii) applies: \", Count[analysisResults, _?(#[\"Lemma1i\"] === \
\"No\" &)]];
Print[\"N/A (no coverage): \", Count[analysisResults, _?(#[\"Lemma1i\"] === \
\"N/A\" &)]];

Dataset[analysisResults[[1 ;; Min[10, Length[analysisResults]]]]]\
\>", "Input",
 CellLabel->
  "In[580]:=",ExpressionUUID->"baeccafb-4a6c-ff44-a706-b65d5d49c613"],

