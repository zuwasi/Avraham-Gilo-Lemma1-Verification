Cell[CellGroupData[{

Cell["\<\
8.3 Panel 3: Aggregate Demand x(q,P) with Heterogeneous Consumers\
\>", "Subsection",ExpressionUUID->"52d02bbc-97ea-af4d-adf0-fd670698835a"],

Cell["\<\
The paper defines aggregate demand (Eq. 2, p.10) as:
  x(q,P) = Integral over theta of alpha_theta*(q,P) * f(theta) d(theta)

We model consumer heterogeneity via gamma ~ Uniform[gammaLow, gammaHigh],
which gives a distribution of CRRA types.\
\>", "Text",ExpressionUUID->"46396274-8de7-ea4a-9627-4e1f18070f2e"],

Cell[CellGroupData[{

Cell["\<\
(* Aggregate demand with uniform distribution of gamma types *)
aggregateDemand[ww_, qq_, pp_, hh_, gLow_, gHigh_, nTypes_: 30] := Module[
  {gammas, alphas},
  gammas = Table[gg, {gg, gLow, gHigh, (gHigh - gLow) / (nTypes - 1)}];
  alphas = Map[
    Function[gg, Quiet[solveAlphaCRRA[ww, qq, pp, hh, gg]]],
    gammas
  ];
  N[Mean[alphas]]
];

Manipulate[
  Module[
    {pVals, xVals, pStarAgg, xStarAgg},
    SeedRandom[42];
    pVals = Table[pp, {pp, 0.005, 1/qVal3 - 0.005, (1/qVal3 - 0.01) / 80}];
    xVals = Map[
      Function[pp, {pp, aggregateDemand[wVal3, qVal3, pp, hVal3, gLow3, \
gHigh3]}],
      pVals
    ];
    {pStarAgg, xStarAgg} = First[SortBy[xVals, -Last[#] &]];
    Column[{
      Style[\"Aggregate Demand x(q,P) with Heterogeneous CRRA Consumers\", \
Bold, 14],
      Row[{
        StringForm[\"Peak at P* = `1`, x* = `2`\", Round[pStarAgg, 0.001], \
Round[xStarAgg, 0.001]]
      }],
      ListLinePlot[xVals,
        PlotLabel -> StringForm[\"x(q,P)  |  \[Gamma] ~ U[`1`,`2`]\", gLow3, \
gHigh3],
        PlotStyle -> {Thick, Darker[Blue]},
        PlotRange -> {{0, Automatic}, {0, 1}},
        Epilog -> {
          Red, PointSize[Large], Point[{pStarAgg, xStarAgg}],
          Text[Style[\"P-bar\", 12, Red, Bold], {pStarAgg, xStarAgg}, {0, \
-1.5}]
        },
        Frame -> True,
        FrameLabel -> {\"Accident Probability P\", \"Aggregate Demand \
x(q,P)\"},
        ImageSize -> 550,
        GridLines -> Automatic
      ]
    }]
  ],
  {{wVal3, 100, \"Wealth W\"}, 50, 500, 10, Appearance -> \"Labeled\"},
  {{hVal3, 40, \"Harm H\"}, 5, 80, 5, Appearance -> \"Labeled\"},
  {{qVal3, 1.3, \"Loading q\"}, 1.01, 3.0, 0.01, Appearance -> \"Labeled\"},
  {{gLow3, 1.0, \"\[Gamma] Low\"}, 0.1, 5.0, 0.1, Appearance -> \"Labeled\"},
  {{gHigh3, 8.0, \"\[Gamma] High\"}, 2.0, 20.0, 0.5, Appearance -> \
\"Labeled\"},
  TrackedSymbols :> {wVal3, hVal3, qVal3, gLow3, gHigh3},
  ControlPlacement -> Left
]\
\>", "Input",
 CellLabel->
  "In[576]:=",ExpressionUUID->"9e536492-b7c8-cb48-acd7-7651825d3834"],

