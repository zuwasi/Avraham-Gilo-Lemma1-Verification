Cell[CellGroupData[{

Cell["5.3 Limit Analysis: P -> 0 (Equation 18-19)", "Subsection",ExpressionUUID->"0294a8b5-3727-2d41-a634-318bb15eae2c"],

Cell["\<\
As P -> 0:
  W1 -> W  (no premium)
  W2 -> W - H*(1 - alpha)

The numerator of Eq.(17) converges to (Eq.18):
  alpha*q*H*[Ra(W) - Ra(W - H*(1-alpha))] + (q - 1)

Lemma 1(i) requires this to be NEGATIVE, i.e. (Eq.19):
  Ra(W) - Ra(W - H*(1-alpha)) < (1 - q) / (alpha*q*H)

For CRRA: Ra(A) = gamma/A, so:
  Ra(W) - Ra(W-H*(1-alpha)) = gamma/W - gamma/(W-H*(1-alpha))
  = gamma * [1/W - 1/(W-H*(1-alpha))]
  = gamma * [-(H*(1-alpha))] / [W*(W-H*(1-alpha))]
  < 0  (since H*(1-alpha) > 0)

So for CRRA, Ra(W) - Ra(W-H*(1-alpha)) is always NEGATIVE.
The RHS (1-q)/(alpha*q*H) is also negative for q > 1.
The question is whether the LHS is sufficiently negative.\
\>", "Text",ExpressionUUID->"5ba63cf8-258a-da46-a3b3-75f9b78173ca"],

Cell[CellGroupData[{

Cell["\<\
(* Equation (18): limit of numerator as P -> 0 *)
numeratorLimitP0[aa_, qq_, hh_, raAtW_, raAtWmH_] :=
  aa * qq * hh * (raAtW - raAtWmH) + (qq - 1);

(* For CRRA *)
numeratorLimitP0CRRA[ww_, aa_, qq_, hh_, gg_] := Module[
  {raW, raWH, wBottom},
  (* Guard: if alpha is 0 or 1, the limit expression simplifies *)
  If[aa < 0.0001, Return[N[qq - 1]]];
  If[aa > 0.9999, Return[N[qq - 1]]]; (* full coverage: W2 = W, Ra difference \
= 0 *)
  wBottom = ww - hh * (1 - aa);
  If[wBottom <= 0, Return[N[-Infinity]]]; (* wealth in accident state \
non-positive *)
  raW = crrArrowPratt[ww, gg];
  raWH = crrArrowPratt[wBottom, gg];
  numeratorLimitP0[aa, qq, hh, raW, raWH]
];

(* Equation (19): condition for Lemma 1(i) *)
lemma1iCondition[ww_, aa_, qq_, hh_, gg_] := Module[
  {lhs, rhs, numP0, wBottom},
  (* Guard: if alpha is zero, condition is undefined *)
  If[aa < 0.0001,
    Return[<|
      \"LHS\" -> \"N/A (alpha~0, no coverage)\",
      \"RHS\" -> \"N/A\",
      \"Satisfied\" -> \"N/A\",
      \"Numerator\" -> N[qq - 1]
    |>]
  ];
  wBottom = ww - hh * (1 - aa);
  If[wBottom <= 0,
    Return[<|
      \"LHS\" -> \"N/A (W2 <= 0)\",
      \"RHS\" -> \"N/A\",
      \"Satisfied\" -> \"N/A\",
      \"Numerator\" -> N[-Infinity]
    |>]
  ];
  lhs = crrArrowPratt[ww, gg] - crrArrowPratt[wBottom, gg];
  rhs = (1 - qq) / (aa * qq * hh);
  numP0 = numeratorLimitP0CRRA[ww, aa, qq, hh, gg];
  <|
    \"LHS\" -> N[lhs],
    \"RHS\" -> N[rhs],
    \"Satisfied\" -> (N[lhs] < N[rhs]),
    \"Numerator\" -> N[numP0]
  |>
];

(* Test across several gamma values *)
Print[\"=== Lemma 1(i) Condition Check for CRRA ===\"];
Print[\"W=100, q=1.3, H=40\"];
Print[\"\"];
Do[
  Module[{aOpt, result},
    aOpt = solveAlphaCRRA[100, 1.3, 0.01, 40, gg];
    If[aOpt < 0.0001,
      Print[\"gamma = \", gg, \", alpha*(P~0) = 0  [no coverage, condition \
N/A]\"],
      result = lemma1iCondition[100, aOpt, 1.3, 40, gg];
      Print[\"gamma = \", gg, \", alpha*(P~0) = \", Round[aOpt, 0.0001]];
      Print[\"  \", result]
    ];
  ],
  {gg, {0.5, 1, 2, 3, 5, 8}}
];\
\>", "Input",
 CellLabel->
  "In[537]:=",ExpressionUUID->"3964fd19-e213-f14d-a77d-074c7cb855b0"],

