In[517]:=",ExpressionUUID->"b25cc5a3-a5c7-284f-b62d-84394e53123e"],

Cell[BoxData["\<\"w.r.t. P yields exactly the expression in the paper's \
Appendix.\"\>"], "Print",
 CellChangeTimes->{3.9839358755698833`*^9},
 CellLabel->
